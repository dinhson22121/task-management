DATABASE_URL="file:./dev.db?connection_limit=1"
# Jira Client ID/Secret are entered in the app's Settings UI, not here — see
# JiraConfig table / jiraConfigService.ts. Redirect URI is always computed
# from PORT below, never configured.
JIRA_AUTHORIZE_URL=https://auth.atlassian.com/authorize
JIRA_TOKEN_URL=https://auth.atlassian.com/oauth/token
NOTIFIER_PROVIDER_NAME=slack
NOTIFIER_CLIENT_ID=
NOTIFIER_CLIENT_SECRET=
NOTIFIER_AUTHORIZE_URL=
NOTIFIER_TOKEN_URL=
NOTIFIER_OAUTH_REDIRECT_URI=
TOKEN_ENCRYPTION_KEY=      # 32-byte hex key, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
PORT=4000
LOCAL_USER_EMAIL=local@device
