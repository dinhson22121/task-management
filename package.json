{
  "name": "task-pool-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Deadline Buddy — Electron desktop app (embedded Express + Prisma/SQLite backend)",
  "author": {
    "name": "Son Ngo",
    "email": "dinhson22121997@gmail.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --runInBand",
    "electron:dev": "npm run build && electron .",
    "dist:mac:dir": "npm run build && electron-builder --mac dir",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:linux": "npm run build && electron-builder --linux deb rpm",
    "setup:piper": "bash scripts/download-piper.sh",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.deadlinebuddy.app",
    "productName": "Deadline Buddy",
    "directories": {
      "output": "release"
    },
    "files": [
      "!**/*",
      "dist/**/*",
      "!dist/__tests__/**/*",
      "electron/**/*",
      "build/icon.png",
      "build/tray-icon.png",
      "build/tray-icon@2x.png",
      "assets/avatar.jpg",
      "notification_popup_mockup.html",
      "prisma/schema.prisma",
      "prisma/migrations/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "package.json"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "node_modules/.prisma",
        "to": "app/node_modules/.prisma"
      },
      {
        "from": "resources/piper/voices",
        "to": "piper/voices"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "resources/piper/mac",
          "to": "piper"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "resources/piper/win",
          "to": "piper"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "extraResources": [
        {
          "from": "resources/piper/linux",
          "to": "piper"
        }
      ]
    }
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "async-mutex": "^0.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "fsevents@2.3.3": true,
    "electron-winstaller@5.4.0": true
  }
}
